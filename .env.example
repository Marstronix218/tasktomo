# OpenAI
# Required for AI companion chat and task completion reactions.
OPENAI_API_KEY=sk-your_openai_api_key

# Model used for all companion chat + reactions. Defaults to gpt-5-mini if unset.
OPENAI_MODEL=gpt-5-mini

# Supabase
# Required for authentication and user data persistence.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Required for server-side Stripe webhook updates.
# Keep this server-only. Never expose it in client-side code.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Stripe
# Required only if enabling Premium subscription checkout.
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_PRICE_ID_YEARLY=price_your_yearly_price_id

# Site URL
# Used for Stripe success and cancel return URLs.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
